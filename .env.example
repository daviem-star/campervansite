# Supabase auth + cloud trip persistence
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional local test auth. These flags enable the explicit local test-user and e2e-only
# routes alongside real Supabase auth; they do not replace magic-link login.
NEXT_PUBLIC_E2E_AUTH_BYPASS=
E2E_AUTH_BYPASS=
NEXT_PUBLIC_LOCAL_TEST_SIGN_IN=

# Live route estimates
OPENROUTESERVICE_API_KEY=
NEXT_PUBLIC_OPENROUTESERVICE_DEBUG=

# Optional map tile source for hosted preview; falls back to OpenStreetMap raster tiles
NEXT_PUBLIC_MAP_TILE_URL_TEMPLATE=
NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=
